{
  "name": "focus20-ai-coach-google-backend",
  "version": "1.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "tsx watch --env-file=.env server/src/index.ts",
      "start:api": "node dist/server/src/index.js",
  "build:api": "tsc -p tsconfig.server.json && node -e \"require('fs').mkdirSync('dist/server',{recursive:true}); require('fs').writeFileSync('dist/server/package.json', JSON.stringify({type:'commonjs'}))\"",
    "dev:full": "concurrently \"npm run dev:api\" \"npm run dev\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "6.19.0",
    "@vitejs/plugin-react": "latest",
    "cors": "latest",
    "dotenv": "latest",
    "express": "latest",
    "framer-motion": "latest",
    "googleapis": "latest",
    "lucide-react": "latest",
    "openai": "^6.37.0",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@types/cors": "latest",
    "@types/express": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "autoprefixer": "latest",
    "concurrently": "latest",
    "postcss": "latest",
    "prisma": "6.19.0",
    "tailwindcss": "^3.4.17",
    "tsx": "latest"
  },
  "engines": {
    "node": ">=20 <25"
  }
}
